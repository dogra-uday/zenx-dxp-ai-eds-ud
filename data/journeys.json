{
  "bfsi": {
    "data": [
      {
        "step": "1",
        "title": "Personal Details",
        "fields": [
          { "name": "fullName", "type": "text", "label": "Full Name" },
          { "name": "dob", "type": "dob", "label": "Date of Birth", "hint": "You must be 18 or older" },
          { "name": "gender", "type": "select", "label": "Gender", "options": ["Male", "Female", "Other"] }
        ]
      },
      {
        "step": "2",
        "title": "Contact Details",
        "fields": [
          { "name": "email", "type": "email", "label": "Email Address" },
          { "name": "mobile", "type": "mobile", "label": "Mobile Number", "hint": "10-digit Indian mobile number" },
          { "name": "address", "type": "text", "label": "Residential Address" }
        ]
      },
      {
        "step": "3",
        "title": "KYC Verification",
        "fields": [
          { "name": "aadhaar", "type": "aadhaar", "label": "Aadhaar Number", "hint": "12 digits" },
          { "name": "pan", "type": "pan", "label": "PAN Number", "hint": "Format: ABCDE1234F" }
        ]
      },
      {
        "step": "4",
        "title": "Employment Details",
        "fields": [
          { "name": "employmentType", "type": "select", "label": "Employment Type", "options": ["Salaried", "Self-Employed", "Student", "Retired"] },
          { "name": "annualIncome", "type": "select", "label": "Annual Income", "options": ["Below ₹5L", "₹5L - ₹10L", "₹10L - ₹25L", "Above ₹25L"] }
        ]
      },
      {
        "step": "5",
        "title": "Account Preferences",
        "fields": [
          { "name": "accountType", "type": "select", "label": "Account Type", "options": ["Savings", "Current"] },
          { "name": "branch", "type": "text", "label": "Preferred Branch" },
          { "name": "initialDeposit", "type": "select", "label": "Initial Deposit", "options": ["₹1,000", "₹5,000", "₹10,000", "₹25,000+"] }
        ]
      },
      {
        "step": "6",
        "title": "Nominee Details",
        "fields": [
          { "name": "hasNominee", "type": "select", "label": "Would you like to add a nominee?", "options": ["Yes", "No"] },
          { "name": "nomineeName", "type": "text", "label": "Nominee Full Name", "condition": { "field": "hasNominee", "equals": "Yes" } },
          { "name": "nomineeRelation", "type": "select", "label": "Relationship to Nominee", "options": ["Spouse", "Parent", "Sibling", "Child", "Other"], "condition": { "field": "hasNominee", "equals": "Yes" } }
        ]
      },
      {
        "step": "7",
        "title": "Review & Submit",
        "fields": []
      }
    ]
  },
  "healthcare": {
    "data": [
      {
        "step": "1",
        "title": "Patient Details",
        "fields": [
          { "name": "fullName", "type": "text", "label": "Full Name" },
          { "name": "dob", "type": "date", "label": "Date of Birth" },
          { "name": "gender", "type": "select", "label": "Gender", "options": ["Male", "Female", "Other"] }
        ]
      },
      {
        "step": "2",
        "title": "Contact Details",
        "fields": [
          { "name": "email", "type": "email", "label": "Email Address" },
          { "name": "mobile", "type": "mobile", "label": "Mobile Number", "hint": "10-digit Indian mobile number" }
        ]
      },
      {
        "step": "3",
        "title": "Patient Status",
        "fields": [
          { "name": "isExistingPatient", "type": "select", "label": "Are you an existing patient?", "options": ["Yes", "No"] },
          { "name": "patientId", "type": "patientId", "label": "Existing Patient ID", "hint": "6-12 alphanumeric characters", "condition": { "field": "isExistingPatient", "equals": "Yes" } }
        ]
      },
      {
        "step": "4",
        "title": "Medical History",
        "fields": [
          { "name": "bloodGroup", "type": "select", "label": "Blood Group", "options": ["A+", "A-", "B+", "B-", "AB+", "AB-", "O+", "O-"] },
          { "name": "allergies", "type": "text", "label": "Known Allergies (if any)", "required": false },
          { "name": "currentMedication", "type": "text", "label": "Current Medication (if any)", "required": false }
        ]
      },
      {
        "step": "5",
        "title": "Insurance Details",
        "fields": [
          { "name": "hasInsurance", "type": "select", "label": "Do you have health insurance?", "options": ["Yes", "No"] },
          { "name": "insuranceProvider", "type": "text", "label": "Insurance Provider", "condition": { "field": "hasInsurance", "equals": "Yes" } },
          { "name": "policyNumber", "type": "text", "label": "Policy Number", "condition": { "field": "hasInsurance", "equals": "Yes" } }
        ]
      },
      {
        "step": "6",
        "title": "Appointment Preferences",
        "fields": [
          { "name": "department", "type": "select", "label": "Department", "options": ["Cardiology", "Dermatology", "Orthopedics", "General Medicine", "Pediatrics"] },
          { "name": "preferredDate", "type": "date", "label": "Preferred Date" },
          { "name": "preferredSlot", "type": "select", "label": "Preferred Slot", "options": ["Morning", "Afternoon", "Evening"] }
        ]
      },
      {
        "step": "7",
        "title": "Review & Submit",
        "fields": []
      }
    ]
  },
  "retail": {
    "data": [
      {
        "step": "1",
        "title": "Customer Details",
        "fields": [
          { "name": "fullName", "type": "text", "label": "Full Name" },
          { "name": "email", "type": "email", "label": "Email Address" },
          { "name": "mobile", "type": "mobile", "label": "Mobile Number", "hint": "10-digit Indian mobile number" }
        ]
      },
      {
        "step": "2",
        "title": "Order Details",
        "fields": [
          { "name": "orderType", "type": "select", "label": "Order Type", "options": ["New Order", "Track Existing Order"] },
          { "name": "orderId", "type": "text", "label": "Order ID", "condition": { "field": "orderType", "equals": "Track Existing Order" } }
        ]
      },
      {
        "step": "3",
        "title": "Delivery Address",
        "fields": [
          { "name": "address", "type": "text", "label": "Address Line" },
          { "name": "city", "type": "text", "label": "City" },
          { "name": "pincode", "type": "pincode", "label": "Pincode", "hint": "6 digits" },
          { "name": "landmark", "type": "text", "label": "Landmark (optional)", "required": false }
        ]
      },
      {
        "step": "4",
        "title": "Delivery Preferences",
        "fields": [
          { "name": "slot", "type": "select", "label": "Preferred Slot", "options": ["Morning", "Afternoon", "Evening"] },
          { "name": "contactlessDelivery", "type": "select", "label": "Contactless Delivery?", "options": ["Yes", "No"] }
        ]
      },
      {
        "step": "5",
        "title": "Payment Method",
        "fields": [
          { "name": "paymentMethod", "type": "select", "label": "Payment Method", "options": ["Cash on Delivery", "Card", "UPI", "Wallet"] },
          { "name": "cardLast4", "type": "cardLast4", "label": "Card Last 4 Digits", "hint": "For verification only", "condition": { "field": "paymentMethod", "equals": "Card" } }
        ]
      },
      {
        "step": "6",
        "title": "Review & Submit",
        "fields": []
      }
    ]
  }
}